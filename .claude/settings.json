{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "yarn test --run",
            "timeout": 120,
            "statusMessage": "Running tests..."
          },
          {
            "type": "command",
            "command": "yarn lint",
            "timeout": 60,
            "statusMessage": "Running lint..."
          },
          {
            "type": "command",
            "command": "yarn knip",
            "timeout": 30,
            "statusMessage": "Running knip..."
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["antd"]
}
